POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
POLYMARKET_HTTP_TIMEOUT_SECONDS=15
POLYMARKET_USER_AGENT=poly-alpha-lab/1.1.0

# Market discovery defaults
POLYMARKET_DEFAULT_LIMIT=20
POLYMARKET_MIN_LIQUIDITY=1000

# Research assumptions, not trading instructions
POLYMARKET_DEFAULT_POSITION_SIZE=100
POLYMARKET_DEFAULT_FAIR_YES_PROBABILITY=0.55
POLYMARKET_MIN_NET_EDGE=0.03
POLYMARKET_JOURNAL_DB_PATH=data/poly_alpha_lab.sqlite
POLYMARKET_WEATHER_BACKTEST_DB_PATH=data/weather_backtest.sqlite
